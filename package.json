{
  "name": "open-osint",
  "version": "0.1.0",
  "private": true,
  "description": "Open Osint - The Investigation Board. Open-source visual intelligence for journalists, analysts and curious citizens.",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @hilo/db generate",
    "db:migrate": "pnpm --filter @hilo/db migrate",
    "db:seed": "pnpm --filter @hilo/db seed",
    "db:studio": "pnpm --filter @hilo/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && node --eval \"require('fs').rmSync('node_modules',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "@types/node": "^22.10.5"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "msgpackr-extract"
    ]
  }
}
