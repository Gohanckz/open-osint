{
  "name": "@hilo/realtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "node --eval \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@hilo/db": "workspace:*",
    "@hilo/shared": "workspace:*",
    "@hocuspocus/server": "^2.15.2",
    "@hocuspocus/extension-redis": "^2.15.2",
    "yjs": "^13.6.21",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
